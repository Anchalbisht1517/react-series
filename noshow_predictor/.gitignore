# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Raw data (user-provided, never commit)
data/raw/

# Streamlit secrets
.streamlit/secrets.toml

# Jupyter Notebook checkpoints
.ipynb_checkpoints
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/*.log
*.log

# Artifacts that should be committed for deployment:
!data/processed/cleaned_appointments_v3.csv
!models/*.pkl
!outputs/plots/*.png
!outputs/model_comparison.csv

# Only ignore large/temporary files
*.tmp
*.bak